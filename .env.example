# Used by ./deploy.sh.

# Where to copy the built dist/ contents.
DEPLOY_TARGET="$HOME/Documents/hotscad"

# Command to run after copying (publish step).
# Leave empty to skip.
DEPLOY_COMMAND="deploy"

# Build script to run before deploying. Use "build" for a quick rebuild (assumes
# libs/wasm are already built), or "build:all" to rebuild libs/fonts/wasm too.
BUILD_SCRIPT="build"

# Set to 1 to mirror the deploy target exactly (delete files that no longer
# exist in dist/). Requires rsync. Default 0 just copies on top of what's there.
MIRROR=1
